{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GetVeripsa/veripsa-webhook-spec/schemas/check-run-signal.schema.json",
  "title": "Veripsa check-run signal",
  "description": "Stable public fields an integrator can branch on after reading a Veripsa GitHub check run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "title",
    "token",
    "conclusion"
  ],
  "properties": {
    "name": {
      "const": "Veripsa"
    },
    "title": {
      "type": "string",
      "description": "Full human-facing check title. Branch on token, not the entire title string."
    },
    "token": {
      "type": "string",
      "enum": [
        "Clear",
        "Clear to land",
        "Heads up",
        "Wait in line",
        "Unknown",
        "Paused (acknowledge to proceed)",
        "Acknowledged",
        "Unresolved merge conflict markers"
      ]
    },
    "conclusion": {
      "type": "string",
      "enum": [
        "success",
        "neutral",
        "action_required"
      ]
    },
    "underlyingVerdict": {
      "type": "string",
      "enum": [
        "clear",
        "heads_up",
        "wait_in_line",
        "unknown",
        "merge_conflict_markers"
      ]
    },
    "prNumber": {
      "type": "integer",
      "minimum": 1
    },
    "repositoryFullName": {
      "type": "string",
      "pattern": "^[^/\\s]+/[^/\\s]+$"
    },
    "headSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "acknowledged": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "token": {
            "const": "Clear"
          }
        },
        "required": [
          "token"
        ]
      },
      "then": {
        "properties": {
          "conclusion": {
            "const": "success"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "token": {
            "const": "Paused (acknowledge to proceed)"
          }
        },
        "required": [
          "token"
        ]
      },
      "then": {
        "properties": {
          "conclusion": {
            "const": "action_required"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "token": {
            "const": "Unresolved merge conflict markers"
          }
        },
        "required": [
          "token"
        ]
      },
      "then": {
        "properties": {
          "conclusion": {
            "const": "action_required"
          }
        }
      }
    }
  ]
}
