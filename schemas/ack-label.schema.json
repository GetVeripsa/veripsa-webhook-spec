{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GetVeripsa/veripsa-webhook-spec/raw/v1.0.0/schemas/ack-label.schema.json",
  "title": "Veripsa ack label contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "meaning", "repositoryDefinitionCreatedBy", "appliedToPullRequestBy", "effectWhenPaused", "staleWhenMaterialCouplingChanges"],
  "properties": {
    "name": {"const": "veripsa-ack"},
    "meaning": {"const": "seen_and_proceeding"},
    "repositoryDefinitionCreatedBy": {"const": "veripsa_when_needed"},
    "appliedToPullRequestBy": {"const": "human_or_agent"},
    "effectWhenPaused": {"const": "action_required_to_neutral"},
    "staleWhenMaterialCouplingChanges": {"const": true}
  }
}
